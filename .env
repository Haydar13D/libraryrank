# ── Django Core ──
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── DATABASE (Ganti isi dengan username dan password MySQL Anda) ──
DB_NAME=libraryrank_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ── KOHA DATABASE (Biarkan sama dengan atas jika Koha & App ada di 1 server MySQL XAMPP) ──
KOHA_DB_NAME=koha
KOHA_DB_USER=root
KOHA_DB_PASSWORD=
KOHA_DB_HOST=127.0.0.1
KOHA_DB_PORT=3306

# ── CAS SSO ──
CAS_SERVER_URL=https://sso.your-university.ac.id/cas/
CAS_VERSION=3
CAS_LOCAL_DEV=True

# ── MAPPING KATEGORI KOHA ──
KOHA_STUDENT_CATEGORIES=S,ST,STUDENT,MAHASISWA
KOHA_LECTURER_CATEGORIES=L,LEC,DOSEN,FACULTY
KOHA_STAFF_CATEGORIES=STAFF,STF,KARYAWAN,PEGAWAI
